# MyFitPick production beta environment
# Copy to .env.local on the server and fill real values there only.

# App URL
NODE_ENV=production
APP_URL=
NEXT_PUBLIC_APP_URL=

# MongoDB
MONGODB_URI=

# Auth/session
JWT_SECRET=
SESSION_COOKIE_NAME=fitpick_session
# Plain HTTP EC2 IP testing needs false. Switch to true when serving over HTTPS.
SESSION_COOKIE_SECURE=false

# Email OTP auth
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="MyFitPick <auth@myfitpick.com>"
OTP_CODE_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# OpenAI
OPENAI_API_KEY=
OPENAI_WARDROBE_MODEL=gpt-4.1-mini
OPENAI_OCR_MODEL=gpt-4.1-mini
OPENAI_STYLIST_MODEL=gpt-4.1-mini
OPENAI_RECOMMENDATION_MODEL=gpt-4.1-mini
OPENAI_IMAGE_GENERATION_MODEL=gpt-image-1
OPENAI_IMAGE_PROMPT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# S3/CloudFront
STORAGE_PROVIDER=s3
S3_BUCKET_NAME=
S3_BUCKET=
S3_REGION=eu-north-1
# Optional for local/static-key deployments. Leave both empty on EC2 when using an IAM role.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CLOUDFRONT_PUBLIC_URL=
S3_PUBLIC_BASE_URL=

# Background jobs
ENABLE_BACKGROUND_JOBS=true
WORKER_POLL_MS=5000

# Credit purchases
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
COINPAYMENTS_API_BASE_URL=https://a-api.coinpayments.net/api/v2
COINPAYMENTS_CLIENT_ID=
COINPAYMENTS_CLIENT_SECRET=
COINPAYMENTS_WEBHOOK_SECRET=
COINPAYMENTS_WEBHOOK_URL=
COINPAYMENTS_USD_CURRENCY_ID=
# JSON array. Use exact CoinPayments providerCurrencyId values from your verified merchant account.
# Intended options: Tron/TRC20, BNB Smart Chain/BEP20, Ethereum/ERC20, Solana.
COINPAYMENTS_USDT_NETWORK_ALLOWLIST=

# Rate limiting/cache
AI_CACHE_PROVIDER=memory
REDIS_URL=
RATE_LIMIT_PROVIDER=memory
RATE_LIMIT_REDIS_URL=
