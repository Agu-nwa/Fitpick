# FitPick production beta environment
# Copy to .env.local on the server and fill real values there only.

# App URL
NODE_ENV=production
APP_URL=https://your-domain.example
NEXT_PUBLIC_APP_URL=https://your-domain.example

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.example/fitpick

# Auth/session
JWT_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=fitpick_session
# Plain HTTP EC2 IP testing needs false. Switch to true when serving over HTTPS.
SESSION_COOKIE_SECURE=false

# OpenAI
OPENAI_API_KEY=sk-replace-with-server-only-key
OPENAI_WARDROBE_MODEL=gpt-4.1-mini
OPENAI_OCR_MODEL=gpt-4.1-mini
OPENAI_STYLIST_MODEL=gpt-4.1-mini
OPENAI_RECOMMENDATION_MODEL=gpt-4.1-mini
OPENAI_IMAGE_GENERATION_MODEL=gpt-image-1
OPENAI_IMAGE_PROMPT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# S3/CloudFront
STORAGE_PROVIDER=s3
S3_BUCKET_NAME=your-fitpick-bucket
S3_BUCKET=your-fitpick-bucket
S3_REGION=eu-north-1
S3_ACCESS_KEY_ID=replace-with-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-secret-access-key
CLOUDFRONT_PUBLIC_URL=https://your-cloudfront-domain.cloudfront.net
S3_PUBLIC_BASE_URL=https://your-cloudfront-domain.cloudfront.net

# Background jobs
ENABLE_BACKGROUND_JOBS=true
WORKER_POLL_MS=5000

# remove.bg studio image processing
BACKGROUND_REMOVAL_PROVIDER=removebg
BACKGROUND_REMOVAL_API_KEY=replace-with-removebg-key
FITPICK_STUDIO_BACKGROUND_PRESET=ivory

# Billing and payments
PAYMENT_PROVIDER=placeholder
PAYSTACK_SECRET_KEY=replace-with-paystack-secret-or-leave-blank
PAYSTACK_PUBLIC_KEY=replace-with-paystack-public-key-or-leave-blank
PAYSTACK_WEBHOOK_SECRET=replace-with-paystack-webhook-secret-or-leave-blank
FITPICK_PLUS_PAYSTACK_PLAN_CODE=replace-with-paystack-plan-code-or-leave-blank
PAYSTACK_CALLBACK_URL=https://your-domain.example/plus
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=replace-with-paystack-public-key-or-leave-blank
STRIPE_SECRET_KEY=replace-with-stripe-secret-or-leave-blank
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret-or-leave-blank
FITPICK_PLUS_STRIPE_PRICE_ID=replace-with-stripe-price-id-or-leave-blank
FITPICK_PLUS_PRICE_ID=replace-with-active-plus-price-id-or-leave-blank
STRIPE_SUCCESS_URL=https://your-domain.example/plus?status=success
STRIPE_CANCEL_URL=https://your-domain.example/plus?status=cancelled

# Rate limiting/cache
AI_CACHE_PROVIDER=memory
REDIS_URL=
RATE_LIMIT_PROVIDER=memory
RATE_LIMIT_REDIS_URL=
